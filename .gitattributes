# Handle line endings automatically for text files
* text=auto

# Code - Ensure LF (Linux style) to prevent Windows vs Mac conflicts
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.py text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf

# Scripts - Preserve specific endings for execution
*.sh text eol=lf
*.bat text eol=crlf

# Documentation
*.md text

# Graphics/Binary - Ensure Git doesn't try to "fix" these (which corrupts them)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff2 binary